#!/usr/bin/env bash
# Configures Nginx to run as the nginx user on port 8080

# nginx starts as root via init, reads this directive, then drops to nginx user
sed -i 's/www-data/nginx/g' /etc/nginx/nginx.conf

# Update the listening port from 80 to 8080 in the default virtual host
sed -i 's/listen 80/listen 8080/g' /etc/nginx/sites-available/default
sed -i 's/listen \[::\]:80/listen [::]:8080/g' /etc/nginx/sites-available/default

# Restart nginx through the init system 
service nginx restart
