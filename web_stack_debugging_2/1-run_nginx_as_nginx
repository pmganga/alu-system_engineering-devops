#!/usr/bin/env bash
# Configures Nginx to run as the nginx user on port 8080

# Stop all nginx processes before making changes
service nginx stop 2>/dev/null
pkill -9 -x nginx 2>/dev/null || true
sleep 1

# Create nginx user if missing
id nginx &>/dev/null || useradd --system --no-create-home --shell /bin/false nginx

# Fix user directive 
sed -i 's/^user www-data;/user nginx;/' /etc/nginx/nginx.conf
sed -i 's/^user www-data www-data;/user nginx;/' /etc/nginx/nginx.conf

# Remove ssl directives
sed -i '/listen.*ssl/d' /etc/nginx/nginx.conf
sed -i '/ssl_/d' /etc/nginx/nginx.conf

# Write the default site config to a temp file then move it into place
cat > /tmp/nginx_default << NGINXEOF
server {
    listen 8080 default_server;
    listen [::]:8080 default_server;
    root /var/www/html;
    index index.html index.htm;
    server_name _;
    location / {
        try_files \$uri \$uri/ =404;
    }
}
NGINXEOF

cp /tmp/nginx_default /etc/nginx/sites-available/default
cp /tmp/nginx_default /etc/nginx/sites-enabled/default

# Gives nginx user ownership of all runtime directories
chown -R nginx:nginx /var/log/nginx
chown -R nginx:nginx /var/lib/nginx
chown -R nginx:nginx /var/www/html

# Pre-create pid file owned by nginx 
touch /var/run/nginx.pid
chown nginx:nginx /var/run/nginx.pid

# Start nginx as the nginx user
# -s overrides the /bin/false shell so su can execute the binary
su -s /bin/bash nginx -c "/usr/sbin/nginx"
