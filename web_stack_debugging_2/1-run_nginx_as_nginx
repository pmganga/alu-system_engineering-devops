#!/usr/bin/env bash
# Configures Nginx to run as the nginx user on port 8080

service nginx stop 2>/dev/null
pkill -9 -x nginx 2>/dev/null || true
sleep 1

# Create nginx user if missing 
id nginx &>/dev/null || useradd --system --no-create-home --shell /bin/false nginx

# Fix the user directive in the main config
sed -i 's/user www-data/user nginx/g' /etc/nginx/nginx.conf

sed -i '/listen.*ssl/d' /etc/nginx/nginx.conf

# Fix port in default site 
sed -i 's/listen 80 default_server/listen 8080 default_server/g' /etc/nginx/sites-available/default
sed -i 's/listen \[::\]:80 default_server/listen [::]:8080 default_server/g' /etc/nginx/sites-available/default
cp /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default

chown -R nginx:nginx /var/log/nginx
chown -R nginx:nginx /var/lib/nginx
chown -R nginx:nginx /var/www/html

touch /var/run/nginx.pid
chown nginx:nginx /var/run/nginx.pid

sudo -u nginx /usr/sbin/nginx
