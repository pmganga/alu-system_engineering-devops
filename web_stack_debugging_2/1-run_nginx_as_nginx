#!/usr/bin/env bash
# Configures Nginx to run as the nginx user on port 8080

# Stop all nginx processes before reconfiguring
service nginx stop 2>/dev/null
pkill -9 -x nginx 2>/dev/null || true
sleep 1

# Create nginx system user if missing in this container
id nginx &>/dev/null || useradd --system --no-create-home --shell /bin/false nginx

# Rewrite nginx.conf 
cat > /etc/nginx/nginx.conf << 'CONF'
user nginx;
worker_processes auto;
pid /tmp/nginx.pid;
events {
    worker_connections 768;
}
http {
    sendfile on;
    include /etc/nginx/mime.types;
    default_type application/octet-stream;
    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log;
    include /etc/nginx/sites-enabled/*;
}
CONF

# Write clean default site on port 8080
cat > /etc/nginx/sites-available/default << 'SITE'
server {
    listen 8080 default_server;
    listen [::]:8080 default_server;
    root /var/www/html;
    index index.html index.htm;
    server_name _;
    location / {
        try_files $uri $uri/ =404;
    }
}
SITE

# Sync sites-enabled with the updated config
cp /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default

chown -R nginx:nginx /var/log/nginx
chown -R nginx:nginx /var/lib/nginx
chown -R nginx:nginx /var/www/html

runuser -u nginx -- /usr/sbin/nginx
