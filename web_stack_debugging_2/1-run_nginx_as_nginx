#!/usr/bin/env bash
# Reconfigures nginx to run as the nginx user and listen on port 8080

service nginx stop
pkill -f nginx

id -u nginx &>/dev/null || useradd -M -s /bin/bash nginx

sed -i 's/80/8080/g' /etc/nginx/sites-available/default

sed -i 's/user www-data;/user nginx;/g' /etc/nginx/nginx.conf
sed -i 's/pid.*/pid \/var\/lib\/nginx\/nginx.pid;/g' /etc/nginx/nginx.conf

mkdir -p /var/lib/nginx
mkdir -p /var/log/nginx
chown -R nginx:nginx /var/lib/nginx
chown -R nginx:nginx /var/log/nginx

sudo -u nginx /usr/sbin/nginx

