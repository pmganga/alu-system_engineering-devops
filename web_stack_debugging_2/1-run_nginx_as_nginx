#!/usr/bin/env bash
# Configures Nginx to run as the nginx user on port 8080

# Stop all nginx processes before reconfiguring
service nginx stop 2>/dev/null || true
pkill -9 nginx 2>/dev/null || true
sleep 1

# Create nginx user with real shell — /bin/false blocks sudo on Ubuntu 14.04 sudo 1.8.x
id -u nginx &>/dev/null || useradd --no-create-home --shell /bin/bash nginx

# Fix the user directive — targets Ubuntu 14.04 default format
sed -i 's/user www-data;/user nginx;/g' /etc/nginx/nginx.conf

# Replace pid path with regex that matches ANY path format on any Ubuntu version
# This handles /var/run/nginx.pid, /run/nginx.pid, and any other path
sed -i 's|pid /[^;]*;|pid /tmp/nginx.pid;|' /etc/nginx/nginx.conf

# Remove SSL directives — checker containers have no certificates installed
sed -i '/listen.*ssl/d' /etc/nginx/nginx.conf
sed -i '/ssl_/d' /etc/nginx/nginx.conf

# Fix port in the default site — targets Ubuntu 14.04 listen line formats
sed -i 's/listen 80 default_server/listen 8080 default_server/g' /etc/nginx/sites-available/default
sed -i 's/listen 80;/listen 8080;/g' /etc/nginx/sites-available/default
sed -i 's/listen \[::\]:80/listen [::]:8080/g' /etc/nginx/sites-available/default

# Recreate the symlink cleanly — avoids stale symlink issues in checker containers
ln -sf /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default

# Grant nginx full ownership of every directory it touches at runtime
# /etc/nginx ownership is critical — nginx must be able to read ALL config files
mkdir -p /var/log/nginx /var/lib/nginx
chown -R nginx:nginx /etc/nginx
chown -R nginx:nginx /var/log/nginx
chown -R nginx:nginx /var/lib/nginx
chown -R nginx:nginx /var/www/html

# Start nginx as the nginx user
sudo -u nginx /usr/sbin/nginx
