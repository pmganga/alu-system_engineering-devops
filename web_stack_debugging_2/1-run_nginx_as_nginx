#!/usr/bin/env bash
# Configures Nginx to run as the nginx user on port 8080

# Handle both commented and uncommented user directive
sed -i 's/#user www-data/user nginx/' /etc/nginx/nginx.conf
sed -i 's/user www-data/user nginx/' /etc/nginx/nginx.conf

# Replace port 80 with 8080 in the default site config
sed -i 's/80/8080/g' /etc/nginx/sites-available/default

# Kill Apache2 - it runs in ALU debugging containers and blocks nginx
pkill apache2

# Restart nginx - starts as root, drops workers to nginx user via config
service nginx restart
