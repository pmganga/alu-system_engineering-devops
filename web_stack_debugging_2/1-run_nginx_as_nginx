#!/usr/bin/env bash
# Configures Nginx to run as the nginx user on port 8080

service nginx stop 2>/dev/null
pkill -9 -x nginx 2>/dev/null || true
sleep 1

# Create nginx system user if missing in this container
id nginx &>/dev/null || useradd --system --no-create-home --shell /bin/false nginx

# Update the user directive
sed -i 's/^user www-data;/user nginx;/' /etc/nginx/nginx.conf
sed -i 's/^user www-data www-data;/user nginx;/' /etc/nginx/nginx.conf

# Move pid to /tmp 
sed -i 's|pid /run/nginx.pid;|pid /tmp/nginx.pid;|' /etc/nginx/nginx.conf
sed -i 's|pid /var/run/nginx.pid;|pid /tmp/nginx.pid;|' /etc/nginx/nginx.conf

# Remove ssl directives 
sed -i '/listen.*ssl/d' /etc/nginx/nginx.conf
sed -i '/ssl_/d' /etc/nginx/nginx.conf

cat > /etc/nginx/sites-available/default << 'SITE'
server {
    listen 8080 default_server;
    listen [::]:8080 default_server;
    root /var/www/html;
    index index.html index.htm;
    server_name _;
    location / {
        try_files $uri $uri/ =404;
    }
}
SITE

# Sync sites-enabled with the updated config
cp /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default

chown -R nginx:nginx /var/log/nginx
chown -R nginx:nginx /var/lib/nginx
chown -R nginx:nginx /var/www/html

sudo -u nginx /usr/sbin/nginx
